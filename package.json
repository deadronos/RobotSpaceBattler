{
  "name": "space-station-autobattler",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:analyze": "vite build --mode production",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --config eslint.config.cjs",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --config eslint.config.cjs --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "ci:test": "cross-env CI=true vitest run --coverage",
    "playwright:install": "playwright install",
    "playwright:test": "playwright test",
    "perf:vfx-instancing": "node ./scripts/perf/measure_drawcalls.js",
    "check:source-size": "node ./scripts/check_source_size.js",
    "check:pr-constitution": "node ./scripts/check_pr_constitution_check.js",
    "typecheck": "tsc --noEmit"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "npm run format"
    ],
    "**/*.{md,json}": [
      "npm run format"
    ]
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "^0.19.3",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@react-three/postprocessing": "^3.0.4",
    "@react-three/rapier": "^2.2.0",
    "@tanstack/react-query": "^5.99.0",
    "miniplex": "^2.0.0",
    "multithreading": "^0.3.52",
    "navmesh": "^2.3.1",
    "postprocessing": "^6.39.0",
    "r3f-perf": "^7.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-draggable": "^4.5.0",
    "three": "^0.183.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@gltf-transform/cli": "^4.3.0",
    "@gltf-transform/core": "^4.3.0",
    "@gltf-transform/extensions": "^4.3.0",
    "@playwright/test": "^1.59.1",
    "@react-three/test-renderer": "^9.1.0",
    "@responsive-image/vite-plugin": "^3.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "@vitest/coverage-v8": "^4.1.4",
    "ajv": "^8.18.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.0",
    "eslint-config-auto": "^0.9.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-playwright": "^2.10.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-vitest": "^0.5.4",
    "gltf-pipeline": "^4.3.1",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.59.1",
    "pngjs": "^7.0.0",
    "prettier": "^3.8.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "^6.0.2",
    "unplugin-auto-import": "^21.0.0",
    "vite": "^8.0.8",
    "vite-plugin-checker": "^0.12.0",
    "vite-plugin-glsl": "^1.6.0",
    "vite-plugin-svgr": "^5.2.0",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "@typescript-eslint/utils": "^8.57.1"
  }
}
